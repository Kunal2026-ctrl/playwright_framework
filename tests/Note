--grep "@Regression"


Handling multiple windows or tabs
syntax  
const[newtab] = await promise.all([
page.waitForEvent("Popup")
page.click("locator")

])

const[newwindow] = await promise.all([
context.waitForEvent("page")
page.click("locator")

])

